# ==============================================================================
# DeerTeamX Environment Configuration Template
# ==============================================================================
# Copy this file to .env.deerteamx and update values for your environment.
# 
# Configuration Loading Priority:
# 1. System environment variables (highest priority)
# 2. .env.deerteamx file
# 3. Default values in code (lowest priority)
#
# Security Notice:
# - NEVER commit .env.deerteamx to version control
# - Use strong, unique keys for production environments
# - Rotate keys regularly (recommended: every 90 days)
# ==============================================================================

# --- 1. Application Metadata ------------------------------------------------

APP_NAME=DeerTeamX
APP_VERSION=1.0.0
# Options: development, staging, production
APP_ENV=development
# Set to false in production
DEBUG=true


# --- 2. Infrastructure (基础设施) -------------------------------------------

# PostgreSQL Database URL for DeerTeamX Business Logic
# Suggestion: Use a dedicated database or schema separate from native DeerFlow
DATABASE_URL=postgresql://deerteamx_user:your_secure_password@localhost:5432/deerteamx_db

# Redis URL for Distributed Locks, Rate Limiting, and Caching
# Suggestion: Use a different DB index (e.g., /1) to avoid key conflicts with DeerFlow
REDIS_URL=redis://localhost:6379/1


# --- 3. Internal Integration (内部服务集成) ---------------------------------

# DeerFlow Gateway Endpoint
# DeerTeamX communicates with the core execution engine via this URL
DEERFLOW_GATEWAY_URL=http://localhost:8001

# Internal Communication Secret (Optional)
# Used for mutual authentication between DeerTeamX and DeerFlow Gateway
DEERFLOW_INTERNAL_SECRET=change-this-to-a-random-string

# Qdrant Vector Database URL (for long-term memory)
QDRANT_URL=http://localhost:6334


# --- 4. Security & Auth (安全与认证) ----------------------------------------

# JWT Secret Key for User Sessions
# CRITICAL: Do NOT share this with the native DeerFlow instance
# Must be at least 32 characters long
JWT_SECRET_KEY=your-super-secret-jwt-key-for-deerteamx-min-32-chars

JWT_ALGORITHM=HS256

# Token Expiration Settings
# 24 hours
ACCESS_TOKEN_EXPIRE_MINUTES=1440
# 7 days
REFRESH_TOKEN_EXPIRE_DAYS=7

# Encryption Master Key for KMS
# Used to encrypt sensitive data (like LLM API Keys) stored in PostgreSQL
# Must be at least 32 characters long
ENCRYPTION_MASTER_KEY=aes-256-gcm-master-key-here-min-32-chars

# Password Hashing
# Range: 10-14 (higher = more secure but slower)
BCRYPT_ROUNDS=12


# --- 5. Rate Limiting (速率限制) --------------------------------------------

RATE_LIMIT_LOGIN_PER_MINUTE=5        # Login attempts per IP
RATE_LIMIT_REGISTER_PER_MINUTE=3     # Registration attempts per IP
RATE_LIMIT_EXECUTION_PER_MINUTE=10   # Execution triggers per user
RATE_LIMIT_IMPORT_PER_MINUTE=3       # Import tasks per user
RATE_LIMIT_READ_PER_MINUTE=60        # Read API calls per user
RATE_LIMIT_WRITE_PER_MINUTE=30       # Write API calls per user


# --- 6. Storage & Paths (存储与路径) ----------------------------------------

# Temporary directory for CrewAI import files
IMPORT_TEMP_DIR=/tmp/deerteamx_imports

# Directory for storing exported results (executions, logs)
EXPORT_RESULTS_DIR=/mnt/user-data/exports

# Persistent storage for knowledge source files
KNOWLEDGE_BASE_DIR=/mnt/user-data/knowledge

# Log file directory
LOG_DIR=/var/log/deerteamx

# File Size Limits (in bytes)
MAX_IMPORT_FILE_SIZE=5242880          # 5 MB
MAX_KNOWLEDGE_FILE_SIZE=10485760      # 10 MB
MAX_TEAM_KNOWLEDGE_SIZE=52428800      # 50 MB


# --- 7. Frontend & Network (前端与网络) -------------------------------------

# Frontend Application URL (for CORS and redirects)
FRONTEND_URL=http://localhost:3000

# Allowed CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,https://your-production-domain.com

# WebSocket Configuration
WEBSOCKET_MAX_CONNECTIONS=1000
WEBSOCKET_AUTH_TIMEOUT=5


# --- 8. Execution Engine (执行引擎) -----------------------------------------

# Execution Lock Settings
EXECUTION_LOCK_TTL=1800                # 30 minutes
EXECUTION_HEARTBEAT_INTERVAL=300       # 5 minutes
EXECUTION_TIMEOUT_DEFAULT=1800         # 30 minutes

# Human Feedback Timeout
HUMAN_FEEDBACK_TIMEOUT_DEFAULT=1800    # 30 minutes (range: 300-7200 seconds)


# --- 9. Background Tasks (后台任务) -----------------------------------------

# Import Task Settings
IMPORT_TASK_TIMEOUT=60                 # 60 seconds
IMPORT_TASK_MAX_PARALLEL=3             # Max parallel imports per user

# Cleanup Policies (in days)
CLEANUP_IMPORT_TASKS_DAYS=7            # Retain completed/failed import tasks
CLEANUP_THREAD_DATA_DAYS=30            # Retain execution thread data

# Temp File TTLs (in seconds)
TEMP_FILE_TTL_IMPORT=3600              # 1 hour
TEMP_FILE_TTL_EXPORT=86400             # 24 hours
TEMP_FILE_TTL_KNOWLEDGE=604800         # 7 days


# --- 10. LocalStorage TTL (Frontend Configuration) --------------------------

LOCALSTORAGE_TTL_FORM_DRAFT=604800     # 7 days (in seconds)
LOCALSTORAGE_TTL_DAG_CANVAS=86400      # 24 hours (in seconds)
LOCALSTORAGE_TTL_IMPORT_PROGRESS=70    # 70 seconds
SESSIONSTORAGE_TTL_SENSITIVE=1800      # 30 minutes (in seconds)


# --- 11. Observability (可观测性 - Optional) --------------------------------

# Enable Prometheus Metrics Exporter
ENABLE_METRICS=false
METRICS_PORT=9090

# OpenTelemetry Tracing Endpoint (if using distributed tracing)
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# Logging Configuration
LOG_LEVEL=INFO                         # DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_FORMAT=json                        # json or text


# --- 12. Feature Flags (功能开关) -------------------------------------------

# Enable/disable experimental or optional features

FEATURE_LONG_TERM_MEMORY=true          # Requires Qdrant service
FEATURE_CONSENSUS_MODE=true            # Consensus process type
FEATURE_HUMAN_FEEDBACK=true            # Human approval workflow
FEATURE_STATE_PERSISTENCE=true         # Breakpoint resume capability
FEATURE_CLI_EXECUTION=false            # CLI execution entry (V1.1 planned)


# ==============================================================================
# Production Deployment Checklist
# ==============================================================================
# Before deploying to production, ensure:
# 
# ✅ JWT_SECRET_KEY is changed to a strong, random value (≥32 chars)
# ✅ ENCRYPTION_MASTER_KEY is changed to a strong, random value (≥32 chars)
# ✅ DEERFLOW_INTERNAL_SECRET is set if using internal auth
# ✅ APP_ENV is set to "production"
# ✅ DEBUG is set to false
# ✅ DATABASE_URL points to production database with SSL enabled
# ✅ REDIS_URL uses TLS (rediss://) if Redis is remote
# ✅ CORS_ORIGINS only includes trusted domains
# ✅ BCRYPT_ROUNDS is set to 12 or higher
# ✅ All file paths exist and have correct permissions
# ✅ QDRANT_URL is accessible if FEATURE_LONG_TERM_MEMORY=true
# ✅ Rate limits are tuned for expected traffic volume
# ✅ Monitoring and alerting are configured (/api/v1/config/health)
# ==============================================================================
